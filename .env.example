ADMIN_USERNAME=admin
# Option A (recommended): SHA-256 hash, format sha256:<hex>
ADMIN_PASSWORD_HASH=
# Option B: plain text fallback (dev only)
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=change-me-in-production

MEDIA_PROVIDER=cloudinary
ADMIN_UPLOAD_MAX_MB=20
ADMIN_UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp,image/avif,video/mp4,video/webm,video/quicktime

# Cloudinary settings (required if MEDIA_PROVIDER=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=dns-service/about
CLOUDINARY_SECURE_DISTRIBUTION=

# S3 settings (reserved for future support)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL_BASE=
S3_UPLOAD_PREFIX=dns-service/about
S3_FORCE_PATH_STYLE=false
